# Copy to .env on VPS and set real values.
# Used by docker-compose.test-deploy.yml.
# Готовый черновик под домен: см. env.vps.template в этом каталоге.

# -------------------------------------------
# Domain and runtime profile
# -------------------------------------------
APP_BASE_URL=https://your-domain.com
JWT_PASSWORD_RESET_BASE_URL=https://your-domain.com/reset-password
SPRING_PROFILES_ACTIVE=prod

# Trust X-Forwarded-* headers from nginx reverse proxy
JWT_TRUST_PROXY=true
# Comma-separated CORS origins (local SPA + prod). Without http://localhost:5173, login from Vite returns 403.
JWT_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com

# -------------------------------------------
# Backend binding
# -------------------------------------------
# Host loopback port for Caddy reverse_proxy (avoid conflicts with existing :8080)
BACKEND_HOST_PORT=18080
# Local `mvn spring-boot:run`: if 8080 is in use, set e.g. SERVER_PORT=18080 (matches BACKEND_HOST_PORT).
# SERVER_PORT=18080

# -------------------------------------------
# Database (postgres service in compose)
# -------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=interhubdev
DB_USER=interhubdev
DB_PASSWORD=change-me-secure-db-password

# -------------------------------------------
# Redis (required password in production)
# -------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-secure-redis-password
REDIS_SSL_ENABLED=false

# -------------------------------------------
# JWT and bootstrap admin
# -------------------------------------------
# Min 32 chars, random secret
JWT_SECRET=change-me-min-32-chars-secure-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-8-chars
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

# -------------------------------------------
# Mail (SMTP)
# -------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=InterHubDev
MAIL_ENABLED=true
MAIL_LOG_ONLY=false
MAIL_USE_STARTTLS=true
MAIL_USE_SSL=false

# -------------------------------------------
# MinIO
# -------------------------------------------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET_NAME=documents
MINIO_REGION=us-east-1

# -------------------------------------------
# ClamAV
# -------------------------------------------
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

# -------------------------------------------
# Telegram Bot (optional — текущий Spring backend это НЕ читает)
# -------------------------------------------
# Нужен только если:
# - отдельный процесс/скрипт бота (Node, Python, …) шлёт сообщения через Bot API, или
# - вы добавите на бэкенд проверку WebApp initData (HMAC с секретом из токена).
# URL Mini App задаётся в @BotFather, токен в .env для этого не обязателен.
# Никогда не коммитьте реальный токен; после утечки — Revoke в BotFather.
# TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token

# -------------------------------------------
# Local dev (Windows): two Postgres on 5432 — use Docker on another host port, then set DB_PORT to match (e.g. 15432 if 5433 is reserved).
# DB_PORT=15432

# -------------------------------------------
# Images/tags (optional overrides)
# -------------------------------------------
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:RELEASE.2026-01-24T17-41-39Z
CLAMAV_IMAGE=clamav/clamav:1.4_base
BACKEND_IMAGE_TAG=latest

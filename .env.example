# Copy to .env on the server and fill in real values.
# Required for docker-compose.production.yaml.

# Profile: prod (HTTPS cookies, HSTS). Add "china" for Alibaba Direct Mail: prod,china
SPRING_PROFILES_ACTIVE=prod

# ===========================================
# Database (must match postgres container: user interhubdev)
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=interhubdev
DB_USER=interhubdev
DB_PASSWORD=change-me-secure-password

# ===========================================
# JWT and admin bootstrap
# ===========================================
# Min 32 characters; e.g. openssl rand -base64 32
JWT_SECRET=change-me-min-32-chars-secure-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-8-chars
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

# ===========================================
# Mail (SMTP)
# ===========================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=InterHubDev
MAIL_ENABLED=true
MAIL_LOG_ONLY=false

# ===========================================
# Application URLs (for emails and CORS)
# ===========================================
APP_BASE_URL=https://your-domain.com
JWT_PASSWORD_RESET_BASE_URL=https://your-domain.com/reset-password
# Comma-separated origins for CORS; e.g. https://your-domain.com
# jwt.cors.allowed-origins is set in application.properties; override via env if needed

# ===========================================
# MinIO (used by app and by minio container)
# ===========================================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET_NAME=documents

# ===========================================
# Redis (optional password for production)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false

# ===========================================
# ClamAV (overridden in compose for app; host/port set to clamav service)
# ===========================================
CLAMAV_ENABLED=true

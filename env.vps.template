# Скопируйте на VPS как `.env` рядом с docker-compose.test-deploy.yml.
# Замените все CHANGE_ME_* и перенесите свои реальные секреты с локальной машины (не коммитьте).

PRIMARY_DOMAIN=interhub.online
APP_BASE_URL=https://interhub.online
JWT_PASSWORD_RESET_BASE_URL=https://interhub.online/reset-password
SPRING_PROFILES_ACTIVE=prod,china
JWT_TRUST_PROXY=true

# Только прод-домен(ы) фронта; localhost не нужен на сервере
JWT_CORS_ALLOWED_ORIGINS=https://interhub.online

BACKEND_PORT=8080
BACKEND_HOST_PORT=18080

DB_HOST=postgres
DB_PORT=5432
DB_NAME=interhubdev
DB_USER=interhubdev
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_SSL_ENABLED=false

JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
JWT_COOKIE_SECURE=true
JWT_COOKIE_DOMAIN=

ADMIN_EMAIL=admin@interhub.online
ADMIN_PASSWORD=CHANGE_ME_ADMIN_MIN_8
ADMIN_FIRST_NAME=Super
ADMIN_LAST_NAME=Admin

MAIL_HOST=smtpdm.aliyun.com
MAIL_PORT=80
MAIL_USERNAME=noreply@interhub.online
MAIL_PASSWORD=CHANGE_ME_SMTP
MAIL_FROM=noreply@interhub.online
MAIL_FROM_NAME=interhub
MAIL_ENABLED=true
MAIL_LOG_ONLY=false
MAIL_USE_STARTTLS=false
MAIL_USE_SSL=false

INVITATION_EXPIRY_DAYS=90d
INVITATION_TOKEN_EXPIRY_HOURS=24h
INVITATION_MAX_EMAIL_ATTEMPTS=3
INVITATION_RETRY_DELAY=60

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET_NAME=documents
MINIO_REGION=us-east-1
MINIO_PREVIEW_URL_EXPIRES_SECONDS=3600

CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=30000
CLAMAV_ENABLED=true

POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:RELEASE.2026-01-24T17-41-39Z
CLAMAV_IMAGE=clamav/clamav:1.4_base
BACKEND_IMAGE_TAG=latest
